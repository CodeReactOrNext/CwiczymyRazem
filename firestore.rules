rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {

      // User can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // User can write their own document, but cannot change role or stripe fields
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !("role"                 in request.resource.data.diff(resource.data).affectedKeys())
        && !("stripeCustomerId"     in request.resource.data.diff(resource.data).affectedKeys())
        && !("stripeSubscriptionId" in request.resource.data.diff(resource.data).affectedKeys())
        && !("premiumUntil"         in request.resource.data.diff(resource.data).affectedKeys());

      // role / stripe fields are written only by the backend (Firebase Admin SDK)
      // Admin SDK bypasses these rules entirely — no extra rule needed
    }

    // ─── Exercise plans ───────────────────────────────────────────────────────
    match /exercisePlans/{planId} {
      // Owner can always read; any auth'd user can read public plans
      allow read:   if request.auth != null
        && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Practice sessions ────────────────────────────────────────────────────
    match /practiceSessions/{sessionId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Daily quests ─────────────────────────────────────────────────────────
    match /dailyQuests/{questId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Community exercises ──────────────────────────────────────────────────
    match /communityExercises/{exerciseId} {
      // Public exercises are readable by anyone logged in; private only by their author
      allow read: if request.auth != null
        && (resource.data.isPublic == true || resource.data.authorId == request.auth.uid);

      // Only the author can create; authorId must match uid
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Author can update their own exercise (but cannot change authorId)
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && !("authorId" in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Ratings subcollection — each user writes only their own rating
      match /ratings/{userId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
