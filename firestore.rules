rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {

      // User can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // User can write their own document, but cannot change role or stripe fields
      allow write: if request.auth != null
        && request.auth.uid == userId
        && !("role"                 in request.resource.data.diff(resource.data).affectedKeys())
        && !("stripeCustomerId"     in request.resource.data.diff(resource.data).affectedKeys())
        && !("stripeSubscriptionId" in request.resource.data.diff(resource.data).affectedKeys())
        && !("premiumUntil"         in request.resource.data.diff(resource.data).affectedKeys());

      // role / stripe fields are written only by the backend (Firebase Admin SDK)
      // Admin SDK bypasses these rules entirely — no extra rule needed

      // Uploaded Guitar Pro files (gp-tabs library) — owner only
      match /gpFiles/{fileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Folders organizing the gp-tabs library — owner only
      match /gpFolders/{folderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-song practice progress (play time, sessions, accuracy, attached GP
      // file, marked parts: riff / solo / whole song) — owner only
      match /songProgress/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-song user metadata (sections, practice notes, YouTube link) — owner only
      match /userSongs/{songId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Exercise plans ───────────────────────────────────────────────────────
    match /exercisePlans/{planId} {
      // Owner can always read; any auth'd user can read public plans
      allow read:   if request.auth != null
        && (resource.data.userId == request.auth.uid || resource.data.isPublic == true);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Practice sessions ────────────────────────────────────────────────────
    match /practiceSessions/{sessionId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Daily quests ─────────────────────────────────────────────────────────
    match /dailyQuests/{questId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Getting-started checklist (dashboard onboarding quest) ─────────────────
    match /onboardingQuests/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─── Community exercises ──────────────────────────────────────────────────
    match /communityExercises/{exerciseId} {
      // Public exercises are readable by anyone logged in; private only by their author
      allow read: if request.auth != null
        && (resource.data.isPublic == true || resource.data.authorId == request.auth.uid);

      // Only the author can create; authorId must match uid
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Author can update their own exercise (but cannot change authorId).
      // Any signed-in user may update ONLY the rating aggregate fields, so
      // people can rate exercises they don't own (rateExercise writes the new
      // average/count onto the exercise doc inside its transaction). Any
      // signed-in user may also bump playCount by starting the exercise —
      // it's a low-stakes, self-serve counter (unlike thanksCount, which
      // gates a fame reward and is only written by the backend below).
      allow update: if request.auth != null && (
        (
          resource.data.authorId == request.auth.uid
          && !("authorId" in request.resource.data.diff(resource.data).affectedKeys())
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'ratingCount'])
          && request.resource.data.averageRating is number
          && request.resource.data.averageRating >= 0
          && request.resource.data.averageRating <= 5
          && request.resource.data.ratingCount is int
          && request.resource.data.ratingCount >= 0
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount'])
          && request.resource.data.playCount is int
          && request.resource.data.playCount >= 0
        )
      );

      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Ratings subcollection — each user writes only their own rating
      match /ratings/{userId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Thanks subcollection — awards the author fame, so it's only ever
      // written by the backend (Admin SDK, see /api/community-exercises/thank),
      // which also bypasses the read rule below. Clients may only read it,
      // e.g. to show whether the current user already thanked the exercise.
      match /thanks/{userId} {
        allow read:  if request.auth != null;
        allow write: if false;
      }

      // Completions subcollection — dedupes the "first completion" fame
      // reward (see /api/community-exercises/complete). Backend-only, same
      // reasoning as thanks above.
      match /completions/{userId} {
        allow read:  if request.auth != null;
        allow write: if false;
      }
    }

    // ─── Song playlists ───────────────────────────────────────────────────────
    match /playlists/{playlistId} {
      // Owner can always read; any auth'd user can read public playlists
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || resource.data.isPublic == true);

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Owner edits their playlist (ownerId immutable). Any signed-in user may
      // update ONLY the popularity fields (importCount / likeCount / likes) on a
      // public playlist — written when they save (copy) or like it.
      allow update: if request.auth != null && (
        (
          resource.data.ownerId == request.auth.uid
          && !("ownerId" in request.resource.data.diff(resource.data).affectedKeys())
        )
        || (
          resource.data.isPublic == true
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['importCount', 'likeCount', 'likes'])
        )
      );

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // ─── Global chat ──────────────────────────────────────────────────────────
    match /chats/{messageId} {
      // Any signed-in user can read and post messages
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Author edits their own message (author fields immutable). Any other
      // signed-in user may update ONLY the "likes" field, to like/unlike it.
      allow update: if request.auth != null && (
        (
          resource.data.userId == request.auth.uid
          && !("userId" in request.resource.data.diff(resource.data).affectedKeys())
        )
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );

      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ─── Arsenal marketplace ──────────────────────────────────────────────────
    // Player-to-player listings. Every mutation (list / buy / cancel, the escrow
    // move, fame transfer and status change) runs server-side via the Firebase
    // Admin SDK, which bypasses these rules. Clients are read-only so a buyer
    // can browse, but can never forge a listing, change a price or mark one sold.
    match /marketplace/{listingId} {
      allow read:  if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ─── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
